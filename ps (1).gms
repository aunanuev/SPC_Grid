* Consolidar retornos y probabilidades
PARAMETER r(i,t), p(i,k,t);
r('SPX',t)    = ret_semanal_spx(t);
r('CMC200',t) = ret_semanal_cmc200(t);
p('SPX',k,t)    = prob_spx(t,k);
p('CMC200',k,t) = prob_cmc200(t,k);

* -------------------------
* 2) Momentos por regimen y mezcla por periodo (Opcion B del PDF)
* -------------------------
PARAMETERS
   den_mu(i,k)             "sum_t p(i,k,t)"
   den_sig(i,j,k)          "sum_t p(i,k,t)*p(j,k,t)"
   mu_hat(i,k)             "media condicional por regimen"
   sigma_hat(i,j,k)        "cov condicional por regimen (pesos producto)"
   mu_mix(i,t)             "media mixta por periodo t"
   sigma_mix(i,j,t)        "cov mixta por periodo t"
   sigma_tmp(i,j,t)        "aux para simetrizar";

den_mu(i,k)    = sum(t, p(i,k,t));
den_sig(i,j,k) = sum(t, p(i,k,t)*p(j,k,t));

mu_hat(i,k)$(den_mu(i,k) > 0) =
    sum(t, p(i,k,t)*r(i,t)) / den_mu(i,k);

sigma_hat(i,j,k)$(den_sig(i,j,k) > 0) =
    sum(t, p(i,k,t)*p(j,k,t)
          *(r(i,t)-mu_hat(i,k))*(r(j,t)-mu_hat(j,k))) / den_sig(i,j,k);

mu_mix(i,t) = sum(k, p(i,k,t)*mu_hat(i,k));
sigma_mix(i,j,t) = sum(k, p(i,k,t)*p(j,k,t)*sigma_hat(i,j,k));

* Simetrizar numericamente
sigma_tmp(i,j,t) = sigma_mix(i,j,t);
sigma_mix(i,j,t) = 0.5*(sigma_tmp(i,j,t) + sigma_tmp(j,i,t));

* -------------------------
* 3) Modelo media-varianza con costos
* -------------------------
SCALARS
   Capital_inicial  / 10000 /
   lambda_riesgo    / 0.10  /;

PARAMETER c_base(i) "costo unitario transmision (tasa sobre rotacion)";
c_base('SPX')    = 0.005;
c_base('CMC200') = 0.010;

PARAMETER c_eff(i) "costo efectivo en FO";
c_eff(i) = c_base(i);

PARAMETER w0(i) "portafolio inicial (max entropia con 2 activos = 50/50)";
w0('SPX')    = 0.5;
w0('CMC200') = 0.5;

VARIABLES
   z           "valor objetivo"
   w(i,t)      "peso del activo i en t"
   u(i,t)      "parte positiva del cambio de peso"
   v(i,t)      "parte negativa del cambio de peso";

POSITIVE VARIABLES u, v;
w.lo(i,t) = 0;  w.up(i,t) = 1;

EQUATIONS
   FO_media_var_costo    "FO: retorno - lambda*var - costos"
   normalizacion_pesos(t)
   rebalanceo_lineal(i,t)
   anclaje_inicial(i);

FO_media_var_costo..
   z =e= sum(t,
              sum(i, w(i,t)*mu_mix(i,t))
            - lambda_riesgo*sum((i,j), w(i,t)*w(j,t)*sigma_mix(i,j,t))
            - sum(i, c_eff(i)*(u(i,t)+v(i,t)))
            );

normalizacion_pesos(t)..  sum(i, w(i,t)) =e= 1;

rebalanceo_lineal(i,t)$(ord(t)>1)..
   w(i,t) - w(i,t-1) =e= u(i,t) - v(i,t);

anclaje_inicial(i)..
   w(i,'t1') - w0(i) =e= u(i,'t1') - v(i,'t1');

MODEL PortafolioEstadosCostos / all /;
OPTION nlp = ipopt;
SOLVE PortafolioEstadosCostos USING nlp MAXIMIZING z;

* -------------------------
* 4) Post: capital ex-post y comparativas
* -------------------------
PARAMETER
   cap_opt(t)        "capital optimo ex-post"
   cap_naive_rb(t)   "capital naive 50-50 con rebalanceo"
   cap_naive_bh(t)   "capital naive buy&hold"
   w_naive(i,t)      "pesos naive (50/50)"
   w_bh_naive(i,t)   "pesos naive buy&hold por drift (pre-rebalanceo)"
   r_port_opt(t)     "retorno portafolio opt (lag)"
   r_port_naive(t)   "retorno portafolio naive (lag)"
   r_port_bh(t)      "retorno portafolio buy&hold (lag)"
   turn_opt(i,t)     "rotacion opt (u+v)"
   turn_naive(i,t)   "rotacion naive (abs diferencia a 0.5)";

w_naive(i,t) = 0.5;

cap_opt('t1')      = Capital_inicial;
cap_naive_rb('t1') = Capital_inicial;
cap_naive_bh('t1') = Capital_inicial;

LOOP(t$(ord(t)>1),
   r_port_opt(t-1)  = sum(i, w.l(i,t-1)*r(i,t-1));
   turn_opt(i,t)    = u.l(i,t) + v.l(i,t);
   cap_opt(t)       = cap_opt(t-1)*(1 + r_port_opt(t-1))
                      - cap_opt(t-1)*sum(i, c_base(i)*turn_opt(i,t));

* Buy&hold naive (sin rebalanceo)
   r_port_bh(t-1)   = sum(i, w_naive(i,t-1)*r(i,t-1));
   cap_naive_bh(t)  = cap_naive_bh(t-1)*(1 + r_port_bh(t-1));

* Pesos pre-rebalanceo para naive (drift)
   w_bh_naive(i,t)  = w_naive(i,t-1)*(1 + r(i,t-1)) / (1 + r_port_bh(t-1));

* Rebalanceo a 50/50 (costos por rotacion)
   r_port_naive(t-1)= sum(i, w_naive(i,t-1)*r(i,t-1));
   turn_naive(i,t)  = abs(w_naive(i,t) - w_bh_naive(i,t));
   cap_naive_rb(t)  = cap_naive_rb(t-1)*(1 + r_port_naive(t-1))
                      - cap_naive_rb(t-1)*sum(i, c_base(i)*turn_naive(i,t));
);

SCALARS
   ret_acum_opt, ret_acum_naive_rb, ret_acum_naive_bh
   inc_cap_opt,  inc_cap_naive_rb,  inc_cap_naive_bh;

ret_acum_opt       = cap_opt('t163')/Capital_inicial - 1;
ret_acum_naive_rb  = cap_naive_rb('t163')/Capital_inicial - 1;
ret_acum_naive_bh  = cap_naive_bh('t163')/Capital_inicial - 1;

inc_cap_opt        = cap_opt('t163')      - Capital_inicial;
inc_cap_naive_rb   = cap_naive_rb('t163') - Capital_inicial;
inc_cap_naive_bh   = cap_naive_bh('t163') - Capital_inicial;

DISPLAY w.l, u.l, v.l, z.l;
DISPLAY cap_opt, ret_acum_opt, inc_cap_opt;
DISPLAY cap_naive_rb, ret_acum_naive_rb, inc_cap_naive_rb;
DISPLAY cap_naive_bh, ret_acum_naive_bh, inc_cap_naive_bh;
DISPLAY mu_mix, sigma_mix;

* -------------------------
* 5) Sensibilidad (grid de lambda y multiplicadores de costo)
* -------------------------
SET L / L1*L5 /, C / C1*C3 /, M / z, cap_final, ret_acum /;
PARAMETER lambda_grid(L), c_mult(C), res(L,C,M);

lambda_grid('L1') = 0.05; lambda_grid('L2') = 0.10; lambda_grid('L3') = 0.20;
lambda_grid('L4') = 0.50; lambda_grid('L5') = 1.00;
c_mult('C1') = 0.5; c_mult('C2') = 1.0; c_mult('C3') = 2.0;

LOOP(L,
  lambda_riesgo = lambda_grid(L);
  LOOP(C,
    c_eff(i) = c_base(i)*c_mult(C);

    SOLVE PortafolioEstadosCostos USING nlp MAXIMIZING z;

    cap_opt(t)    = 0; cap_opt('t1') = Capital_inicial;
    LOOP(t$(ord(t)>1),
      r_port_opt(t-1)  = sum(i, w.l(i,t-1)*r(i,t-1));
      turn_opt(i,t)    = u.l(i,t) + v.l(i,t);
      cap_opt(t)       = cap_opt(t-1)*(1 + r_port_opt(t-1))
                         - cap_opt(t-1)*sum(i, c_base(i)*turn_opt(i,t));
    );
    res(L,C,'z')         = z.l;
    res(L,C,'cap_final') = cap_opt('t163');
    res(L,C,'ret_acum')  = cap_opt('t163')/Capital_inicial - 1;
  );
);
DISPLAY lambda_grid, c_mult, res;

* Exportar a GDX para analisis externo (Python/R)
* gdx=tmp en la linea de comandos y pasar a excel con botón derecho
*execute_unload 'res.gdx', w, u, v, cap_opt, cap_naive_rb, cap_naive_bh, mu_mix, sigma_mix, res;
